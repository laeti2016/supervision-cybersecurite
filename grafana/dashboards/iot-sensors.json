{
  "title": "IoT — Capteurs",
  "uid": "iot-sensors",
  "schemaVersion": 39,
  "refresh": "15s",
  "panels": [
    {
      "title": "Temperature par capteur (C)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sensor_temperature",
          "legendFormat": "{{device_id}} - {{location}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius" }
      }
    },
    {
      "title": "Pression par capteur (hPa)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sensor_pression",
          "legendFormat": "{{device_id}} - {{location}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pressurehpa" }
      }
    },
    {
      "title": "Niveau batterie (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sensor_batterie",
          "legendFormat": "{{device_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Vibration par capteur",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sensor_vibration",
          "legendFormat": "{{device_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
